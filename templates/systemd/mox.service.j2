[Unit]
Description=Mox mail server.
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart={{ mox___app._bin }} serve
ExecStop={{ mox___app._bin }} stop
WorkingDirectory={{ mox___app._var_d }}
RestartSec=5s
Restart=always
UMask=0007
LimitNOFILE=65535
SyslogFacility=mail
PrivateDevices=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths={{ mox__cfg._config_d }} {{ mox__cfg._data_d }}
ProtectKernelTunables=true
ProtectControlGroups=true
AmbientCapabilities=
CapabilityBoundingSet=CAP_SETUID
CapabilityBoundingSet=CAP_SETGID
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_CHOWN
CapabilityBoundingSet=CAP_FSETID
CapabilityBoundingSet=CAP_DAC_OVERRIDE
CapabilityBoundingSet=CAP_DAC_READ_SEARCH
CapabilityBoundingSet=CAP_FOWNER
CapabilityBoundingSet=CAP_KILL
NoNewPrivileges=true
RestrictAddressFamilies=AF_INET
RestrictAddressFamilies=AF_INET6
RestrictAddressFamilies=AF_UNIX
RestrictAddressFamilies=AF_NETLINK
ProtectProc=invisible
RestrictNamespaces=true
RestrictRealtime=true
RemoveIPC=true
ProtectHostname=true
ProtectClock=true
ProtectKernel_logs=true
ProtectKernel_modules=true
MemoryDenyWriteExecute=true
LockPersonality=true
SystemCallArchitectures=native
SystemCallFilterAllow=@system-service
DevicePolicy=closed

[Install]
WantedBy=multi-user.target